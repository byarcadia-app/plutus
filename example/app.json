{
  "expo": {
    "name": "plutus-example",
    "slug": "plutus-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "plutusexample",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.domwozniak.plutus-example",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "2ed1ab64-95aa-420b-adbe-79a0f746b8a2"
      }
    },
    "owner": "dominikwozniak"
  }
}
