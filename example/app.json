{
  "expo": {
    "name": "plutus-example",
    "slug": "plutus-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "plutusexample",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arcadia.plutus-example"
    },
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
